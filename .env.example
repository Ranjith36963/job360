# Job360 Configuration
# Copy to .env and fill in your values

# ── Job Board API Keys (keyed sources skip gracefully if unset) ──
REED_API_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JSEARCH_API_KEY=
JOOBLE_API_KEY=
SERPAPI_KEY=
CAREERJET_AFFID=
FINDWORK_API_KEY=

# ── Email Notifications (Gmail App Password) ──
SMTP_EMAIL=
SMTP_PASSWORD=
NOTIFY_EMAIL=

# ── GitHub Token (optional — for higher API rate limits during profile enrichment) ──
GITHUB_TOKEN=

# ── Slack / Discord Webhooks (optional) ──
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# ── LLM-Powered CV Parsing (optional — supplements regex parsing) ──
# Supported providers: "anthropic" or "openai"
# LLM_API_KEY=
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-6

# ── Tunable Parameters ──
# TARGET_SALARY_MIN=40000        # GBP annual — used for tiebreaker sorting
# TARGET_SALARY_MAX=120000       # GBP annual — used for tiebreaker sorting
# MIN_MATCH_SCORE=30             # Minimum score (0-100) to keep a job
# MAX_RESULTS_PER_SOURCE=100     # Max jobs fetched per source per run
# MAX_DAYS_OLD=7                 # Ignore jobs older than N days
