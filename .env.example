# Job360 Configuration
# Copy to .env and fill in your values

# GROUP A: Job Board API Keys
REED_API_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JSEARCH_API_KEY=
JOOBLE_API_KEY=
SERPAPI_KEY=
CAREERJET_AFFID=
FINDWORK_API_KEY=

# Email Notifications (Gmail App Password)
SMTP_EMAIL=
SMTP_PASSWORD=
NOTIFY_EMAIL=

# GitHub Token (optional — for higher API rate limits during profile enrichment)
GITHUB_TOKEN=

# Salary range (optional — used for tiebreaker sorting)
TARGET_SALARY_MIN=40000
TARGET_SALARY_MAX=120000

# Slack / Discord Webhooks (optional)
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
