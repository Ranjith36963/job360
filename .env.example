# Job360 Configuration
# Copy to .env and fill in your values

# ── Job Board API Keys (keyed sources skip gracefully if unset) ──
REED_API_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JSEARCH_API_KEY=
JOOBLE_API_KEY=
SERPAPI_KEY=
CAREERJET_AFFID=
FINDWORK_API_KEY=

# ── Email Notifications (Gmail App Password) ──
SMTP_EMAIL=
SMTP_PASSWORD=
NOTIFY_EMAIL=

# ── GitHub Token (optional — for higher API rate limits during profile enrichment) ──
GITHUB_TOKEN=

# ── Slack / Discord Webhooks (optional) ──
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# ── LLM Intelligence (optional — free providers, $0 cost) ──
# Set ANY combination of keys — even 1 works. More = more capacity + resilience.
# Auto-rotates across all configured providers to avoid rate limits.
#
# RECOMMENDED (get all 3 for ~3000 free requests/day):
# GROQ_API_KEY=           # https://console.groq.com → 30 RPM, 1K/day, no card
# GEMINI_API_KEY=         # https://ai.google.dev → 15 RPM, 1K/day, no card
# CEREBRAS_API_KEY=       # https://cloud.cerebras.ai → 30 RPM, 1M tok/day, no card
#
# OPTIONAL (extra capacity):
# DEEPSEEK_API_KEY=       # https://platform.deepseek.com → 5M tokens free (30 days), no card
# OPENROUTER_API_KEY=     # https://openrouter.ai → 20 RPM, 50/day free models, no card
# SAMBANOVA_API_KEY=      # https://cloud.sambanova.ai → 20 RPD (very limited), no card

# ── Tunable Parameters ──
# TARGET_SALARY_MIN=40000        # GBP annual — used for tiebreaker sorting
# TARGET_SALARY_MAX=120000       # GBP annual — used for tiebreaker sorting
# MIN_MATCH_SCORE=30             # Minimum score (0-100) to keep a job
# MAX_RESULTS_PER_SOURCE=100     # Max jobs fetched per source per run
# MAX_DAYS_OLD=7                 # Ignore jobs older than N days
