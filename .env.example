# Job360 Configuration
# Copy to .env and fill in your values.
# All vars are optional unless flagged REQUIRED IN PROD.

# === Required in production ===
# itsdangerous signing secret for session cookies. Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=
# Fernet key for encrypting channel credentials. Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CHANNEL_ENCRYPTION_KEY=

# === Runtime environment ===
# Set to "prod" to mark session cookies Secure (HTTPS-only). Leave blank for dev.
JOB360_ENV=
# CORS allow-list for the Next.js frontend. Comma-separated for multiple origins.
FRONTEND_ORIGIN=http://localhost:3000
# Logging verbosity. DEBUG / INFO / WARNING / ERROR.
LOG_LEVEL=INFO
# Redis broker URL — only required when running the ARQ worker.
REDIS_URL=redis://localhost:6379

# === LLM providers (at least one required for CV parsing) ===
# Google Gemini free tier — https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Groq free tier — https://console.groq.com/keys
GROQ_API_KEY=
# Cerebras free tier — https://cloud.cerebras.ai/
CEREBRAS_API_KEY=

# === Job board APIs (all optional — free sources work without any) ===
# Reed — https://www.reed.co.uk/developers/jobseeker
REED_API_KEY=
# Adzuna — https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# JSearch (via RapidAPI) — https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=
# Jooble — https://jooble.org/api/about
JOOBLE_API_KEY=
# SerpAPI (Google Jobs) — https://serpapi.com/users/sign_up
SERPAPI_KEY=
# Careerjet affiliate ID — https://www.careerjet.com/partners/
CAREERJET_AFFID=
# Findwork — https://findwork.dev/developers/
FINDWORK_API_KEY=

# === GitHub profile enrichment ===
# Optional personal access token — raises public API rate limit from 60 → 5000/hr.
# Create at https://github.com/settings/tokens (no scopes needed for public data).
GITHUB_TOKEN=

# === Email notifications ===
# Gmail SMTP + app password — https://myaccount.google.com/apppasswords
SMTP_EMAIL=
SMTP_PASSWORD=
NOTIFY_EMAIL=

# === Slack / Discord webhooks ===
# Slack incoming webhook — https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
# Discord channel webhook — https://support.discord.com/hc/en-us/articles/228383668
DISCORD_WEBHOOK_URL=

# === Scoring weights + gate thresholds (Pillar 2) ===
# Minimum title-component fraction for a job to pass the gate (0.0–1.0).
MIN_TITLE_GATE=0.15
# Minimum skill-component fraction for a job to pass the gate (0.0–1.0).
MIN_SKILL_GATE=0.15
# Dimension weights in the 7-dim scorer.
SALARY_WEIGHT=10
SENIORITY_WEIGHT=8
VISA_WEIGHT=6
WORKPLACE_WEIGHT=6
# Target salary range (GBP) — used for tiebreaker sorting + salary scoring.
TARGET_SALARY_MIN=40000
TARGET_SALARY_MAX=120000

# === Feature flags ===
# Enable sentence-transformers + ChromaDB semantic retrieval (requires [semantic] extra).
SEMANTIC_ENABLED=false
# Enable LLM-based job enrichment pipeline.
ENRICHMENT_ENABLED=false
# Min match_score above which a job is enriched via LLM. Default 60.
ENRICHMENT_THRESHOLD=60

# === Scraper overrides (advanced) ===
# 80000Hours uses the site's public Algolia keys by default — these work out of the box.
# Only override if the public keys rotate upstream.
EIGHTYKHOURS_ALGOLIA_APP_ID=
EIGHTYKHOURS_ALGOLIA_API_KEY=
