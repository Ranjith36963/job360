# Job360 Configuration
# Copy to .env and fill in your values

# GROUP A: Job Board API Keys
REED_API_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JSEARCH_API_KEY=
JOOBLE_API_KEY=
SERPAPI_KEY=
CAREERJET_AFFID=
FINDWORK_API_KEY=

# Email Notifications (Gmail App Password)
SMTP_EMAIL=
SMTP_PASSWORD=
NOTIFY_EMAIL=

# GitHub Token (optional — for higher API rate limits during profile enrichment)
GITHUB_TOKEN=

# Slack / Discord Webhooks (optional)
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# Salary range for tiebreaker sorting (optional, defaults shown)
TARGET_SALARY_MIN=40000
TARGET_SALARY_MAX=120000

# 80,000 Hours Algolia search key (optional override — defaults work out of the box)
# EIGHTYKHOURS_ALGOLIA_APP_ID=W6KM1UDIB3
# EIGHTYKHOURS_ALGOLIA_SEARCH_KEY=d1d7f2c8696e7b36837d5ed337c4a319
